@model TiendaWeb.Models.Pedido

@{
    ViewData["Title"] = $"Pedido #{Model.Id}";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Detalle del Pedido #@Model.Id</h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Información del pedido</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <strong>Cliente:</strong> @Model.Cliente
                </div>
                <div class="col-md-4">
                    <strong>Fecha:</strong> @Model.Fecha.ToString("dd/MM/yyyy HH:mm")
                </div>
                <div class="col-md-4">
                    <strong>Total:</strong> <span class="text-success fw-bold">@Model.Total.ToString("C2")</span>
                </div>
            </div>
        </div>
    </div>

    <h4>Productos en este pedido</h4>
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Producto</th>
                <th>Categoría</th>
                <th>Precio unit.</th>
                <th>Cantidad</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.PedidoProductos)
            {
                <tr>
                    <td>@item.Producto?.Nombre</td>
                    <td>@item.Producto?.Categoria?.Nombre</td>
                    <td>@item.PrecioUnitario.ToString("C2")</td>
                    <td>@item.Cantidad</td>
                    <td>@((item.PrecioUnitario * item.Cantidad).ToString("C2"))</td>
                </tr>
            }
        </tbody>
        <tfoot class="table-secondary">
            <tr>
                <td colspan="4" class="text-end"><strong>Total:</strong></td>
                <td><strong>@Model.Total.ToString("C2")</strong></td>
            </tr>
        </tfoot>
    </table>
</div>