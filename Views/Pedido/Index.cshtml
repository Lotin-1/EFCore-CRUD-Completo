@model IEnumerable<TiendaWeb.Models.Pedido>

@{
    ViewData["Title"] = "Pedidos";
}

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-cart"></i> Lista de Pedidos</h2>
        <a asp-action="Crear" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Pedido
        </a>
    </div>

    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Cliente</th>
                <th>Fecha</th>
                <th>Total</th>
                <th>Productos</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td><strong>@item.Cliente</strong></td>
                    <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.Total.ToString("C2")</td>
                    <td>
                        <span class="badge bg-info">@item.PedidoProductos?.Count() ?? 0 productos</span>
                    </td>
                    <td>
                        <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-sm btn-info">Ver</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>